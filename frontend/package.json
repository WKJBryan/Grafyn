{
  "name": "grafyn-frontend",
  "version": "0.3.0",
  "type": "module",
  "description": "Grafyn frontend - Vue 3 SPA for knowledge management",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare:sidecar": "node scripts/prepare-sidecar.cjs",
    "check:file-sizes": "node scripts/check-file-sizes.cjs",
    "tauri": "tauri",
    "tauri:dev": "node scripts/run-tauri.cjs dev",
    "tauri:build": "node scripts/run-tauri.cjs build",
    "version:bump": "node scripts/bump-version.cjs",
    "release:verify": "node scripts/release-verify.cjs",
    "release:prepare": "node scripts/release-tag.cjs --prepare-only",
    "release:tag": "node scripts/release-tag.cjs",
    "generate-icons": "node scripts/generate-icons.cjs && npx tauri icon src-tauri/icons/app-icon.png",
    "e2e": "echo 'Manual only: the Playwright suite needs a live Tauri IPC backend (run \"npm run tauri:dev\" first), so it cannot run against a plain browser or in CI. See e2e/README.md.' && cd ../e2e && npm install && npm test"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.6.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dompurify": "^3.3.3",
    "marked": "^11.0.0",
    "pinia": "^2.1.0",
    "vue": "^3.5.38",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.0",
    "@tauri-apps/cli": "^1.6.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.16",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.0",
    "jsdom": "^23.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "vite": "^8.1.0",
    "vitest": "^4.0.16"
  }
}
