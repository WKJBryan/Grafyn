# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Paths
VAULT_PATH=../vault
DATA_PATH=../data

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# OAuth Configuration (for ChatGPT MCP)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://your-name.ngrok.io/auth/callback

# Security Configuration
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-encryption-key-here

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_DAY=200
RATE_LIMIT_PER_HOUR=50
RATE_LIMIT_PER_MINUTE=10

# Environment
ENVIRONMENT=development

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-api-key

# Feedback Configuration (GitHub Issues)
# Create a PAT at https://github.com/settings/tokens with issues:write scope
GITHUB_FEEDBACK_REPO=owner/repo-name
GITHUB_FEEDBACK_TOKEN=ghp_your_personal_access_token
